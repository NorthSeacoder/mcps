# NAS 环境变量模板
# 复制为 nas.local.env 并填入真实值，不要提交 .local 文件

# --- hermes-db ---
HERMES_PG_DSN=postgresql://user:password@your-nas-host:5432/hermes
HERMES_REDIS_URL=redis://your-nas-host:6379/0
HERMES_EMBEDDING_BASE_URL=http://your-nas-host:3000/v1
HERMES_EMBEDDING_API_KEY=sk-your-token
HERMES_EMBEDDING_MODEL=BAAI/bge-m3
HERMES_EMBEDDING_DIMENSION=1024
HERMES_API_TOKEN=

# --- 镜像仓库 ---
REGISTRY=ghcr.io/northseacoder
